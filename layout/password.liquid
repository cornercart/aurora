<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Sora:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'cc-blue': '#1D4AFE',
            'cc-navy': '#112F54',
            'cc-dark': '#0D1340',
            'cc-muted': '#50436F',
            'cc-light': '#F5F7FA',
          },
          fontFamily: {
            'heading': ['Sora', 'sans-serif'],
            'body': ['Inter', 'sans-serif'],
          },
          borderRadius: {
            'pill': '63px',
          },
        },
      },
    }
  </script>

  <style>
    body { font-family: 'Inter', sans-serif; margin: 0; }
    h1, h2, h3, h4, h5, h6 { font-family: 'Sora', sans-serif; }
  </style>

  {{ content_for_header }}
</head>
<body class="font-body text-cc-navy antialiased min-h-screen flex flex-col">
  <main class="flex-1">
    {{ content_for_layout }}
  </main>
</body>
</html>
