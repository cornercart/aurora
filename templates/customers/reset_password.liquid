<section class="py-12 md:py-20">
  <div class="max-w-md mx-auto px-6">
    <h1 class="font-heading text-3xl font-bold text-cc-dark mb-8 text-center">Reset Password</h1>

    {% form 'reset_customer_password' %}
      <div class="flex flex-col gap-4">
        {%- if form.errors -%}
          <div class="bg-red-50 text-red-600 text-sm rounded-xl p-4">{{ form.errors | default_errors }}</div>
        {%- endif -%}

        <div class="flex flex-col gap-1">
          <label for="Password" class="text-sm font-semibold text-cc-navy">New password</label>
          <input type="password" name="customer[password]" id="Password" autocomplete="new-password" required
            class="border border-gray-200 rounded-xl px-4 py-3 text-sm font-body focus:outline-none focus:ring-2 focus:ring-cc-blue/30">
        </div>

        <div class="flex flex-col gap-1">
          <label for="PasswordConfirmation" class="text-sm font-semibold text-cc-navy">Confirm new password</label>
          <input type="password" name="customer[password_confirmation]" id="PasswordConfirmation" autocomplete="new-password" required
            class="border border-gray-200 rounded-xl px-4 py-3 text-sm font-body focus:outline-none focus:ring-2 focus:ring-cc-blue/30">
        </div>

        <button type="submit" class="w-full bg-cc-blue text-white font-heading font-semibold text-base py-4 rounded-pill hover:opacity-90 transition-opacity">Reset password</button>
      </div>
    {% endform %}
  </div>
</section>
