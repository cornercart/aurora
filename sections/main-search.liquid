<section class="py-12 md:py-20">
  <div class="max-w-[1400px] mx-auto px-6">
    <h1 class="font-heading text-3xl md:text-4xl font-bold text-cc-dark mb-4">Search</h1>

    <form action="{{ routes.search_url }}" method="get" class="mb-10 max-w-xl">
      <div class="flex">
        <input
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="Search..."
          class="flex-1 border border-gray-200 rounded-l-xl px-5 py-3 text-sm font-body focus:outline-none focus:ring-2 focus:ring-cc-blue/30"
        >
        <button type="submit" class="bg-cc-blue text-white font-heading font-semibold text-sm px-6 py-3 rounded-r-xl hover:opacity-90 transition-opacity">Search</button>
      </div>
    </form>

    {%- if search.performed -%}
      <p class="text-sm text-cc-muted mb-8">{{ search.results_count }} results for &ldquo;{{ search.terms }}&rdquo;</p>

      {%- if search.results.size > 0 -%}
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
          {%- for item in search.results -%}
            <a href="{{ item.url }}" class="group block">
              {%- if item.featured_media -%}
                <div class="aspect-square rounded-2xl overflow-hidden bg-cc-light mb-4">
                  {{ item.featured_media | image_url: width: 400 | image_tag:
                    class: 'w-full h-full object-cover group-hover:scale-105 transition-transform duration-300',
                    loading: 'lazy'
                  }}
                </div>
              {%- elsif item.image -%}
                <div class="aspect-square rounded-2xl overflow-hidden bg-cc-light mb-4">
                  {{ item.image | image_url: width: 400 | image_tag:
                    class: 'w-full h-full object-cover group-hover:scale-105 transition-transform duration-300',
                    loading: 'lazy'
                  }}
                </div>
              {%- endif -%}
              <h3 class="font-heading text-sm font-semibold text-cc-navy group-hover:text-cc-blue transition-colors">{{ item.title }}</h3>
              {%- if item.price -%}
                <p class="mt-1 text-sm text-cc-muted">{{ item.price | money }}</p>
              {%- endif -%}
            </a>
          {%- endfor -%}
        </div>
      {%- else -%}
        <p class="text-cc-muted font-body">No results found. Try a different search term.</p>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Search",
  "tag": "section",
  "settings": []
}
{% endschema %}
