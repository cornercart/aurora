<section class="min-h-[60vh] flex items-center justify-center py-20">
  <div class="max-w-md mx-auto px-6 text-center">
    <h1 class="font-heading text-3xl font-bold text-cc-dark mb-4">{{ shop.name }}</h1>
    <p class="text-cc-muted font-body mb-8">{{ shop.password_message }}</p>

    {% form 'storefront_password' %}
      <div class="flex flex-col gap-4">
        {%- if form.errors -%}
          <p class="text-sm text-red-500">{{ form.errors | default_errors }}</p>
        {%- endif -%}
        <input
          type="password"
          name="password"
          placeholder="Enter store password"
          class="border border-gray-200 rounded-xl px-4 py-3 text-sm font-body focus:outline-none focus:ring-2 focus:ring-cc-blue/30"
        >
        <button type="submit" class="bg-cc-blue text-white font-heading font-semibold text-sm py-3 px-6 rounded-pill hover:opacity-90 transition-opacity">Enter</button>
      </div>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Password",
  "tag": "section",
  "settings": []
}
{% endschema %}
