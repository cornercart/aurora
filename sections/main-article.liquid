<section class="py-12 md:py-20">
  <div class="max-w-[800px] mx-auto px-6">
    <div class="mb-8">
      <a href="{{ blog.url }}" class="text-sm font-medium text-cc-blue hover:underline">&larr; Back to {{ blog.title }}</a>
    </div>

    <header class="mb-10">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-cc-dark leading-tight">{{ article.title }}</h1>
      <div class="flex items-center gap-3 mt-4 text-sm text-cc-muted">
        <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%B %d, %Y' }}</time>
        {%- if article.author -%}
          <span>&middot;</span>
          <span>{{ article.author }}</span>
        {%- endif -%}
      </div>
    </header>

    {%- if article.image -%}
      <div class="aspect-[16/9] rounded-2xl overflow-hidden bg-cc-light mb-10">
        {{ article.image | image_url: width: 1200 | image_tag:
          class: 'w-full h-full object-cover',
          loading: 'eager',
          widths: '600,800,1200'
        }}
      </div>
    {%- endif -%}

    <div class="prose prose-lg max-w-none font-body text-cc-navy leading-relaxed
      prose-headings:font-heading prose-headings:text-cc-dark
      prose-a:text-cc-blue prose-a:no-underline hover:prose-a:underline
      prose-img:rounded-xl">
      {{ article.content }}
    </div>

    {%- if blog.comments_enabled? -%}
      <div class="mt-16 pt-10 border-t border-gray-100">
        <h2 class="font-heading text-2xl font-bold text-cc-dark mb-8">
          {{ article.comments_count }} {{ article.comments_count | pluralize: 'comment', 'comments' }}
        </h2>

        {%- for comment in article.comments -%}
          <div class="mb-6 pb-6 border-b border-gray-50">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-sm font-semibold text-cc-navy">{{ comment.author }}</span>
              <span class="text-xs text-cc-muted">{{ comment.created_at | date: '%B %d, %Y' }}</span>
            </div>
            <div class="text-sm text-cc-muted">{{ comment.content }}</div>
          </div>
        {%- endfor -%}

        {% form 'new_comment', article %}
          <div class="flex flex-col gap-4 mt-8">
            <h3 class="font-heading text-lg font-semibold text-cc-dark">Leave a comment</h3>
            <input type="text" name="comment[author]" placeholder="Name" required class="border border-gray-200 rounded-xl px-4 py-3 text-sm font-body focus:outline-none focus:ring-2 focus:ring-cc-blue/30">
            <input type="email" name="comment[email]" placeholder="Email" required class="border border-gray-200 rounded-xl px-4 py-3 text-sm font-body focus:outline-none focus:ring-2 focus:ring-cc-blue/30">
            <textarea name="comment[body]" placeholder="Your comment" rows="4" required class="border border-gray-200 rounded-xl px-4 py-3 text-sm font-body focus:outline-none focus:ring-2 focus:ring-cc-blue/30 resize-y"></textarea>
            <button type="submit" class="self-start bg-cc-blue text-white font-heading font-semibold text-sm py-3 px-6 rounded-pill hover:opacity-90 transition-opacity">Post comment</button>
          </div>
        {% endform %}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Article",
  "tag": "section",
  "settings": []
}
{% endschema %}
