{%- liquid
  assign bg_color = section.settings.bg_color | default: '#0D1340'
  assign text_color = section.settings.text_color | default: '#ffffff'
  assign muted_color = section.settings.muted_color | default: '#9CA3AF'
  assign border_color = section.settings.border_color | default: '#ffffff15'
-%}

<footer class="w-full relative overflow-hidden" {{ section.shopify_attributes }}>
  {% render 'section-background',
    bg_type: section.settings.bg_type,
    bg_color: section.settings.bg_color,
      linear_color_1: section.settings.linear_color_1,
      linear_color_2: section.settings.linear_color_2,
      linear_angle: section.settings.linear_angle,
    gradient_color_1: section.settings.gradient_color_1,
    gradient_color_2: section.settings.gradient_color_2,
    gradient_color_3: section.settings.gradient_color_3,
    gradient_color_4: section.settings.gradient_color_4,
    gradient_color_5: section.settings.gradient_color_5,
    gradient_speed: section.settings.gradient_speed,
    gradient_intensity: section.settings.gradient_intensity,
    show_wave: section.settings.show_wave,
    wave_color: section.settings.wave_color,
    wave_height: section.settings.wave_height,
    show_lines: section.settings.show_lines,
    line_color: section.settings.line_color,
    line_opacity: section.settings.line_opacity,
    line_count: section.settings.line_count,
    line_thickness: section.settings.line_thickness
  %}

  <div class="max-w-[1400px] mx-auto px-6 pt-16 pb-8 relative z-10">

    {%- comment -%} Top: Logo/description + link columns {%- endcomment -%}
    <div class="grid grid-cols-2 md:grid-cols-6 gap-8 lg:gap-12">

      {%- comment -%} Brand column — spans 2 cols {%- endcomment -%}
      <div class="col-span-2">
        {%- if section.settings.logo != blank -%}
          <div class="mb-4" style="max-width: {{ section.settings.logo_max_width | default: 140 }}px;">
            {{ section.settings.logo | image_url: width: 400 | image_tag: class: 'w-full h-auto', loading: 'lazy' }}
          </div>
        {%- else -%}
          <p class="font-heading font-bold text-xl mb-4" style="color: {{ text_color }};">
            {{ shop.name }}
          </p>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="text-sm leading-relaxed max-w-xs" style="color: {{ muted_color }};">
            {{ section.settings.description }}
          </p>
        {%- endif -%}

        {%- comment -%} Social icons {%- endcomment -%}
        {%- if section.settings.social_twitter != blank or section.settings.social_instagram != blank or section.settings.social_facebook != blank or section.settings.social_linkedin != blank or section.settings.social_youtube != blank -%}
          <div class="flex items-center gap-4 mt-6">
            {%- if section.settings.social_facebook != blank -%}
              <a href="{{ section.settings.social_facebook }}" target="_blank" rel="noopener" class="opacity-60 hover:opacity-100 transition-opacity" aria-label="Facebook">
                <svg class="w-5 h-5" fill="currentColor" style="color: {{ muted_color }};" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
              </a>
            {%- endif -%}
            {%- if section.settings.social_instagram != blank -%}
              <a href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener" class="opacity-60 hover:opacity-100 transition-opacity" aria-label="Instagram">
                <svg class="w-5 h-5" fill="currentColor" style="color: {{ muted_color }};" viewBox="0 0 24 24"><path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"/></svg>
              </a>
            {%- endif -%}
            {%- if section.settings.social_twitter != blank -%}
              <a href="{{ section.settings.social_twitter }}" target="_blank" rel="noopener" class="opacity-60 hover:opacity-100 transition-opacity" aria-label="X / Twitter">
                <svg class="w-5 h-5" fill="currentColor" style="color: {{ muted_color }};" viewBox="0 0 24 24"><path d="M13.6823 10.6218L20.2391 3H18.6854L12.9921 9.61788L8.44486 3H3.2002L10.0765 13.0074L3.2002 21H4.75404L10.7663 14.0113L15.5685 21H20.8131L13.6819 10.6218H13.6823ZM11.5541 13.0956L10.8574 12.0991L5.31391 4.16971H7.70053L12.1742 10.5689L12.8709 11.5655L18.6861 19.8835H16.2995L11.5541 13.096V13.0956Z"/></svg>
              </a>
            {%- endif -%}
            {%- if section.settings.social_linkedin != blank -%}
              <a href="{{ section.settings.social_linkedin }}" target="_blank" rel="noopener" class="opacity-60 hover:opacity-100 transition-opacity" aria-label="LinkedIn">
                <svg class="w-5 h-5" fill="currentColor" style="color: {{ muted_color }};" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            {%- endif -%}
            {%- if section.settings.social_youtube != blank -%}
              <a href="{{ section.settings.social_youtube }}" target="_blank" rel="noopener" class="opacity-60 hover:opacity-100 transition-opacity" aria-label="YouTube">
                <svg class="w-5 h-5" fill="currentColor" style="color: {{ muted_color }};" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Link columns from blocks {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_column' -%}
          <div class="col-span-1" {{ block.shopify_attributes }}>
            {%- if block.settings.column_title != blank -%}
              <h3 class="text-sm font-heading font-semibold tracking-wide mb-4" style="color: {{ text_color }};">
                {{ block.settings.column_title }}
              </h3>
            {%- endif -%}
            <ul class="flex flex-col gap-3">
              {%- if block.settings.link_1_label != blank -%}
                <li><a href="{{ block.settings.link_1_url }}" class="text-sm transition-opacity hover:opacity-100 opacity-60" style="color: {{ muted_color }};">{{ block.settings.link_1_label }}</a></li>
              {%- endif -%}
              {%- if block.settings.link_2_label != blank -%}
                <li><a href="{{ block.settings.link_2_url }}" class="text-sm transition-opacity hover:opacity-100 opacity-60" style="color: {{ muted_color }};">{{ block.settings.link_2_label }}</a></li>
              {%- endif -%}
              {%- if block.settings.link_3_label != blank -%}
                <li><a href="{{ block.settings.link_3_url }}" class="text-sm transition-opacity hover:opacity-100 opacity-60" style="color: {{ muted_color }};">{{ block.settings.link_3_label }}</a></li>
              {%- endif -%}
              {%- if block.settings.link_4_label != blank -%}
                <li><a href="{{ block.settings.link_4_url }}" class="text-sm transition-opacity hover:opacity-100 opacity-60" style="color: {{ muted_color }};">{{ block.settings.link_4_label }}</a></li>
              {%- endif -%}
              {%- if block.settings.link_5_label != blank -%}
                <li><a href="{{ block.settings.link_5_url }}" class="text-sm transition-opacity hover:opacity-100 opacity-60" style="color: {{ muted_color }};">{{ block.settings.link_5_label }}</a></li>
              {%- endif -%}
              {%- if block.settings.link_6_label != blank -%}
                <li><a href="{{ block.settings.link_6_url }}" class="text-sm transition-opacity hover:opacity-100 opacity-60" style="color: {{ muted_color }};">{{ block.settings.link_6_label }}</a></li>
              {%- endif -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>

    {%- comment -%} Bottom bar {%- endcomment -%}
    <div class="mt-12 pt-8 border-t flex flex-col sm:flex-row justify-between items-center gap-4" style="border-color: {{ border_color }};">
      <p class="text-sm" style="color: {{ muted_color }};">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
      </p>
      {%- if section.settings.bottom_links != blank -%}
        <div class="flex items-center gap-6">
          {%- assign bottom_items = section.settings.bottom_links.links -%}
          {%- for link in bottom_items -%}
            <a href="{{ link.url }}" class="text-sm opacity-60 hover:opacity-100 transition-opacity" style="color: {{ muted_color }};">{{ link.title }}</a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo"
    },
    {
      "type": "range",
      "id": "logo_max_width",
      "label": "Logo max width (px)",
      "min": 60,
      "max": 300,
      "step": 10,
      "default": 140
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Making commerce better for everyone with smart cart solutions."
    },
    {
      "type": "header",
      "content": "Social Links"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "X / Twitter"
    },
    {
      "type": "url",
      "id": "social_linkedin",
      "label": "LinkedIn"
    },
    {
      "type": "url",
      "id": "social_youtube",
      "label": "YouTube"
    },
    {
      "type": "header",
      "content": "Bottom Bar"
    },
    {
      "type": "link_list",
      "id": "bottom_links",
      "label": "Bottom links (e.g. Privacy, Terms)",
      "info": "Create a menu in Navigation and select it here"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "select",
      "id": "bg_type",
      "label": "Background type",
      "options": [
        { "value": "solid", "label": "Solid color" },
        { "value": "linear", "label": "Linear gradient" },
        { "value": "animated", "label": "Animated gradient" }
      ],
      "default": "solid"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "info": "Used when gradient is disabled",
      "default": "#0D1340"
    },
    {
      "type": "color",
      "id": "linear_color_1",
      "label": "Linear gradient start",
      "default": "#1D4AFE"
    },
    {
      "type": "color",
      "id": "linear_color_2",
      "label": "Linear gradient end",
      "default": "#6C3AED"
    },
    {
      "type": "range",
      "id": "linear_angle",
      "label": "Gradient angle (degrees)",
      "min": 0,
      "max": 360,
      "step": 15,
      "default": 180
    },
    {
      "type": "color",
      "id": "gradient_color_1",
      "label": "Gradient color 1",
      "default": "#1D4AFE"
    },
    {
      "type": "color",
      "id": "gradient_color_2",
      "label": "Gradient color 2",
      "default": "#CFD4F2"
    },
    {
      "type": "color",
      "id": "gradient_color_3",
      "label": "Gradient color 3",
      "default": "#DECFF2"
    },
    {
      "type": "color",
      "id": "gradient_color_4",
      "label": "Gradient color 4",
      "default": "#3B82FF"
    },
    {
      "type": "color",
      "id": "gradient_color_5",
      "label": "Gradient color 5",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "gradient_speed",
      "label": "Gradient speed",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "gradient_intensity",
      "label": "Gradient intensity",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 1
    },
    {
      "type": "checkbox",
      "id": "show_wave",
      "label": "Show wave",
      "default": false
    },
    {
      "type": "color",
      "id": "wave_color",
      "label": "Wave color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "wave_height",
      "label": "Wave height",
      "min": 5,
      "max": 50,
      "step": 1,
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "show_lines",
      "label": "Show lines",
      "default": false
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Line color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "line_opacity",
      "label": "Line opacity",
      "min": 2,
      "max": 50,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "line_count",
      "label": "Line count",
      "min": 5,
      "max": 80,
      "step": 1,
      "default": 30
    },
    {
      "type": "range",
      "id": "line_thickness",
      "label": "Line thickness",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 3
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Body text / links",
      "default": "#9CA3AF"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#374151"
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link Column",
      "settings": [
        {
          "type": "text",
          "id": "column_title",
          "label": "Column heading",
          "default": "Product"
        },
        {
          "type": "text",
          "id": "link_1_label",
          "label": "Link 1 label",
          "default": "Features"
        },
        {
          "type": "url",
          "id": "link_1_url",
          "label": "Link 1 URL"
        },
        {
          "type": "text",
          "id": "link_2_label",
          "label": "Link 2 label",
          "default": "Pricing"
        },
        {
          "type": "url",
          "id": "link_2_url",
          "label": "Link 2 URL"
        },
        {
          "type": "text",
          "id": "link_3_label",
          "label": "Link 3 label"
        },
        {
          "type": "url",
          "id": "link_3_url",
          "label": "Link 3 URL"
        },
        {
          "type": "text",
          "id": "link_4_label",
          "label": "Link 4 label"
        },
        {
          "type": "url",
          "id": "link_4_url",
          "label": "Link 4 URL"
        },
        {
          "type": "text",
          "id": "link_5_label",
          "label": "Link 5 label"
        },
        {
          "type": "url",
          "id": "link_5_url",
          "label": "Link 5 URL"
        },
        {
          "type": "text",
          "id": "link_6_label",
          "label": "Link 6 label"
        },
        {
          "type": "url",
          "id": "link_6_url",
          "label": "Link 6 URL"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_column",
        "settings": {
          "column_title": "Product",
          "link_1_label": "Features",
          "link_2_label": "Pricing",
          "link_3_label": "Integrations",
          "link_4_label": "Changelog"
        }
      },
      {
        "type": "link_column",
        "settings": {
          "column_title": "Company",
          "link_1_label": "About",
          "link_2_label": "Blog",
          "link_3_label": "Careers",
          "link_4_label": "Contact"
        }
      },
      {
        "type": "link_column",
        "settings": {
          "column_title": "Resources",
          "link_1_label": "Help Center",
          "link_2_label": "Documentation",
          "link_3_label": "Guides",
          "link_4_label": "API Reference"
        }
      },
      {
        "type": "link_column",
        "settings": {
          "column_title": "Legal",
          "link_1_label": "Privacy Policy",
          "link_2_label": "Terms of Service",
          "link_3_label": "Cookie Policy"
        }
      }
    ]
  }
}
{% endschema %}
