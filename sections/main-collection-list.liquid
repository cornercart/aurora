<section class="py-12 md:py-20">
  <div class="max-w-[1400px] mx-auto px-6">
    <h1 class="font-heading text-3xl md:text-4xl font-bold text-cc-dark mb-10">Collections</h1>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {%- for collection in collections -%}
        {%- unless collection.handle == 'all' -%}
          <a href="{{ collection.url }}" class="group block">
            <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-cc-light mb-4">
              {%- if collection.featured_image -%}
                {{ collection.featured_image | image_url: width: 600 | image_tag:
                  class: 'w-full h-full object-cover group-hover:scale-105 transition-transform duration-300',
                  loading: 'lazy',
                  widths: '400,600'
                }}
              {%- endif -%}
            </div>
            <h2 class="font-heading text-lg font-semibold text-cc-navy group-hover:text-cc-blue transition-colors">{{ collection.title }}</h2>
            <p class="mt-1 text-sm text-cc-muted">{{ collection.products_count }} {{ collection.products_count | pluralize: 'product', 'products' }}</p>
          </a>
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection List",
  "tag": "section",
  "settings": []
}
{% endschema %}
