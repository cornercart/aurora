<section class="py-12 md:py-20">
  <div class="max-w-[1400px] mx-auto px-6">
    <h1 class="font-heading text-3xl md:text-4xl font-bold text-cc-dark mb-10">Your cart</h1>

    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <input type="hidden" name="_method" value="put">

        <!-- Cart Items -->
        <div class="lg:col-span-2">
          <!-- Table header (desktop) -->
          <div class="hidden md:grid grid-cols-12 gap-4 pb-4 border-b border-gray-200 text-xs font-semibold text-cc-muted uppercase tracking-wide font-body">
            <div class="col-span-6">Product</div>
            <div class="col-span-2 text-center">Price</div>
            <div class="col-span-2 text-center">Quantity</div>
            <div class="col-span-2 text-right">Total</div>
          </div>

          {%- for item in cart.items -%}
            <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-center py-6 border-b border-gray-100">
              <!-- Product info -->
              <div class="md:col-span-6 flex gap-4">
                <a href="{{ item.url }}" class="shrink-0">
                  <div class="w-20 h-20 rounded-xl overflow-hidden bg-cc-light">
                    {%- if item.image -%}
                      <img
                        src="{{ item.image | image_url: width: 200 }}"
                        alt="{{ item.image.alt | escape }}"
                        class="w-full h-full object-cover"
                        loading="lazy"
                      >
                    {%- endif -%}
                  </div>
                </a>
                <div class="flex flex-col justify-center gap-1">
                  <a href="{{ item.url }}" class="font-heading text-sm font-semibold text-cc-dark hover:text-cc-blue transition-colors">{{ item.product.title }}</a>
                  {%- unless item.product.has_only_default_variant -%}
                    <p class="text-xs text-cc-muted font-body">{{ item.variant.title }}</p>
                  {%- endunless -%}
                  <a href="{{ item.url_to_remove }}" class="text-xs text-cc-muted hover:text-red-500 transition-colors font-body mt-1">Remove</a>
                </div>
              </div>

              <!-- Price -->
              <div class="md:col-span-2 text-sm text-cc-muted font-body md:text-center">
                <span class="md:hidden text-xs font-semibold text-cc-muted uppercase tracking-wide mr-2">Price:</span>
                {{ item.original_price | money }}
              </div>

              <!-- Quantity -->
              <div class="md:col-span-2 md:flex md:justify-center">
                <label for="updates_{{ item.key }}" class="sr-only">Quantity for {{ item.product.title }}</label>
                <input
                  type="number"
                  name="updates[]"
                  id="updates_{{ item.key }}"
                  value="{{ item.quantity }}"
                  min="0"
                  class="w-16 text-center text-sm py-2 border border-gray-200 rounded-lg font-body text-cc-dark focus:outline-none focus:ring-2 focus:ring-cc-blue/30 focus:border-cc-blue"
                >
              </div>

              <!-- Line total -->
              <div class="md:col-span-2 text-sm font-semibold text-cc-dark font-body md:text-right">
                <span class="md:hidden text-xs font-semibold text-cc-muted uppercase tracking-wide mr-2">Total:</span>
                {{ item.final_line_price | money }}
              </div>
            </div>
          {%- endfor -%}

          <div class="mt-6">
            <button type="submit" class="btn-secondary text-sm">Update cart</button>
          </div>
        </div>

        <!-- Cart Summary -->
        <div class="lg:col-span-1">
          <div class="bg-cc-light rounded-2xl p-8 flex flex-col gap-4 sticky top-8">
            <h2 class="font-heading text-lg font-bold text-cc-dark">Order summary</h2>
            <div class="flex justify-between items-center pt-4 border-t border-gray-200">
              <span class="text-sm text-cc-muted font-body">Subtotal</span>
              <span class="font-heading font-bold text-lg text-cc-dark">{{ cart.total_price | money }}</span>
            </div>
            <p class="text-xs text-cc-muted font-body">Shipping and taxes calculated at checkout.</p>

            <a href="/checkout" class="btn-primary w-full text-center mt-2">
              Check out
            </a>

            <a href="/collections/all" class="block text-center text-sm text-cc-blue hover:underline font-body">Continue shopping</a>
          </div>
        </div>
      </form>
    {%- else -%}
      <div class="text-center py-20">
        <div class="mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 mx-auto text-cc-muted opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
          </svg>
        </div>
        <p class="text-cc-muted font-body text-lg mb-6">Your cart is empty.</p>
        <a href="/collections/all" class="btn-primary inline-block">
          Continue shopping
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "settings": []
}
{% endschema %}
