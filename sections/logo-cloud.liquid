{%- liquid
  assign speed = section.settings.scroll_speed | default: 30
  assign logo_height = section.settings.logo_height | default: 32
  assign gap = section.settings.gap | default: 64
  assign row_gap = section.settings.row_gap | default: 24
-%}

<section
  class="relative overflow-hidden py-10 md:py-16"
  {{ section.shopify_attributes }}
>
  {% render 'section-background',
    bg_type: section.settings.bg_type,
    bg_color: section.settings.bg_color,
      linear_color_1: section.settings.linear_color_1,
      linear_color_2: section.settings.linear_color_2,
      linear_angle: section.settings.linear_angle,
    gradient_color_1: section.settings.gradient_color_1,
    gradient_color_2: section.settings.gradient_color_2,
    gradient_color_3: section.settings.gradient_color_3,
    gradient_color_4: section.settings.gradient_color_4,
    gradient_color_5: section.settings.gradient_color_5,
    gradient_speed: section.settings.gradient_speed,
    gradient_intensity: section.settings.gradient_intensity,
    show_wave: section.settings.show_wave,
    wave_color: section.settings.wave_color,
    wave_height: section.settings.wave_height,
    show_lines: section.settings.show_lines,
    line_color: section.settings.line_color,
    line_opacity: section.settings.line_opacity,
    line_count: section.settings.line_count,
    line_thickness: section.settings.line_thickness
  %}
  {%- if section.settings.heading != blank -%}
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 mb-8 {% if section.settings.heading_center %}text-center{% endif %}">
      <p class="text-sm font-semibold {% if section.settings.text_light %}text-white/70{% else %}text-cc-muted{% endif %} uppercase tracking-wide">
        {{ section.settings.heading }}
      </p>
    </div>
  {%- endif -%}

  <div class="relative z-10 flex flex-col" style="gap: {{ row_gap }}px;">
    <!-- Row 1: scrolls left -->
    {%- assign row_1_blocks = section.blocks | where: 'type', 'logo_row_1' -%}
    {%- if row_1_blocks.size > 0 -%}
      <div class="logo-scroll-container overflow-hidden" aria-hidden="true">
        <div
          class="logo-scroll-track flex items-center w-max"
          style="gap: {{ gap }}px; animation: logo-scroll-left {{ speed }}s linear infinite;"
        >
          {%- for pass in (1..2) -%}
            {%- for block in row_1_blocks -%}
              <div class="shrink-0 flex items-center justify-center" {{ block.shopify_attributes }}>
                {%- if block.settings.logo != blank -%}
                  {{ block.settings.logo | image_url: height: logo_height | image_tag:
                    class: 'object-contain opacity-60 hover:opacity-100 transition-opacity',
                    loading: 'lazy',
                    style: 'height: ' | append: logo_height | append: 'px; width: auto;'
                  }}
                {%- else -%}
                  <div class="h-8 w-24 rounded bg-gray-200/50 flex items-center justify-center">
                    <span class="text-xs text-gray-400">Logo</span>
                  </div>
                {%- endif -%}
              </div>
            {%- endfor -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    <!-- Row 2: scrolls right -->
    {%- assign row_2_blocks = section.blocks | where: 'type', 'logo_row_2' -%}
    {%- if row_2_blocks.size > 0 -%}
      <div class="logo-scroll-container overflow-hidden" aria-hidden="true">
        <div
          class="logo-scroll-track flex items-center w-max"
          style="gap: {{ gap }}px; animation: logo-scroll-right {{ speed }}s linear infinite;"
        >
          {%- for pass in (1..2) -%}
            {%- for block in row_2_blocks -%}
              <div class="shrink-0 flex items-center justify-center" {{ block.shopify_attributes }}>
                {%- if block.settings.logo != blank -%}
                  {{ block.settings.logo | image_url: height: logo_height | image_tag:
                    class: 'object-contain opacity-60 hover:opacity-100 transition-opacity',
                    loading: 'lazy',
                    style: 'height: ' | append: logo_height | append: 'px; width: auto;'
                  }}
                {%- else -%}
                  <div class="h-8 w-24 rounded bg-gray-200/50 flex items-center justify-center">
                    <span class="text-xs text-gray-400">Logo</span>
                  </div>
                {%- endif -%}
              </div>
            {%- endfor -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>

  <!-- Fade edges -->
  {%- unless section.settings.disable_fade -%}
    {%- if section.settings.transparent_bg -%}
      <div class="pointer-events-none absolute inset-y-0 left-0 w-24 md:w-40 bg-gradient-to-r from-cc-dark/80 to-transparent z-10"></div>
      <div class="pointer-events-none absolute inset-y-0 right-0 w-24 md:w-40 bg-gradient-to-l from-cc-dark/80 to-transparent z-10"></div>
    {%- else -%}
      <div class="pointer-events-none absolute inset-y-0 left-0 w-24 md:w-40 bg-gradient-to-r from-cc-light to-transparent z-10"></div>
      <div class="pointer-events-none absolute inset-y-0 right-0 w-24 md:w-40 bg-gradient-to-l from-cc-light to-transparent z-10"></div>
    {%- endif -%}
  {%- endunless -%}
</section>

<style>
  @keyframes logo-scroll-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @keyframes logo-scroll-right {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }
  .logo-scroll-container:hover .logo-scroll-track {
    animation-play-state: paused;
  }
</style>

{% schema %}
{
  "name": "Logo Cloud",
  "tag": "div",
  "class": "logo-cloud-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading text",
      "default": "Trusted by 10,000+ Shopify merchants"
    },
    {
      "type": "checkbox",
      "id": "heading_center",
      "label": "Center heading",
      "default": true
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "select",
      "id": "bg_type",
      "label": "Background type",
      "options": [
        { "value": "solid", "label": "Solid color" },
        { "value": "linear", "label": "Linear gradient" },
        { "value": "animated", "label": "Animated gradient" }
      ],
      "default": "solid"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F5F7FA",
      "info": "Used when gradient is disabled"
    },
    {
      "type": "color",
      "id": "linear_color_1",
      "label": "Linear gradient start",
      "default": "#1D4AFE"
    },
    {
      "type": "color",
      "id": "linear_color_2",
      "label": "Linear gradient end",
      "default": "#6C3AED"
    },
    {
      "type": "range",
      "id": "linear_angle",
      "label": "Gradient angle (degrees)",
      "min": 0,
      "max": 360,
      "step": 15,
      "default": 180
    },
    {
      "type": "color",
      "id": "gradient_color_1",
      "label": "Gradient color 1",
      "default": "#1D4AFE"
    },
    {
      "type": "color",
      "id": "gradient_color_2",
      "label": "Gradient color 2",
      "default": "#CFD4F2"
    },
    {
      "type": "color",
      "id": "gradient_color_3",
      "label": "Gradient color 3",
      "default": "#DECFF2"
    },
    {
      "type": "color",
      "id": "gradient_color_4",
      "label": "Gradient color 4",
      "default": "#3B82FF"
    },
    {
      "type": "color",
      "id": "gradient_color_5",
      "label": "Gradient color 5",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "gradient_speed",
      "label": "Animation speed",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 2,
      "info": "1 = slow, 10 = fast"
    },
    {
      "type": "range",
      "id": "gradient_intensity",
      "label": "Wave intensity",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 1
    },
    {
      "type": "checkbox",
      "id": "show_wave",
      "label": "Show bottom wave",
      "default": false
    },
    {
      "type": "color",
      "id": "wave_color",
      "label": "Wave color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "wave_height",
      "label": "Wave height (%)",
      "min": 5,
      "max": 50,
      "step": 5,
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "show_lines",
      "label": "Show wave lines",
      "default": false
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Line color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "line_opacity",
      "label": "Line opacity (%)",
      "min": 2,
      "max": 50,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "line_count",
      "label": "Number of lines",
      "min": 5,
      "max": 80,
      "step": 5,
      "default": 30
    },
    {
      "type": "range",
      "id": "line_thickness",
      "label": "Line thickness",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 3
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "checkbox",
      "id": "text_light",
      "label": "Light text",
      "default": false,
      "info": "Enable for dark backgrounds"
    },
    {
      "type": "checkbox",
      "id": "disable_fade",
      "label": "Disable edge fade",
      "default": false
    },
    {
      "type": "header",
      "content": "Scroll Settings"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scroll duration (seconds)",
      "min": 10,
      "max": 80,
      "step": 5,
      "default": 30,
      "info": "Lower = faster"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height (px)",
      "min": 16,
      "max": 64,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between logos (px)",
      "min": 24,
      "max": 120,
      "step": 8,
      "default": 64
    },
    {
      "type": "range",
      "id": "row_gap",
      "label": "Gap between rows (px)",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "logo_row_1",
      "name": "Logo (Row 1)",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        }
      ]
    },
    {
      "type": "logo_row_2",
      "name": "Logo (Row 2)",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo Cloud",
      "blocks": [
        { "type": "logo_row_1" },
        { "type": "logo_row_1" },
        { "type": "logo_row_1" },
        { "type": "logo_row_1" },
        { "type": "logo_row_1" },
        { "type": "logo_row_1" },
        { "type": "logo_row_2" },
        { "type": "logo_row_2" },
        { "type": "logo_row_2" },
        { "type": "logo_row_2" },
        { "type": "logo_row_2" },
        { "type": "logo_row_2" }
      ]
    }
  ]
}
{% endschema %}
