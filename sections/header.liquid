<!-- Header section placeholder — to be designed -->
<header class="w-full py-4">
  <div class="max-w-[1400px] mx-auto px-6 flex items-center justify-between">
    {%- if section.settings.logo -%}
      <a href="/" class="block">
        <img
          src="{{ section.settings.logo | image_url: width: 200 }}"
          alt="{{ shop.name }}"
          class="h-8 w-auto"
          loading="eager"
        >
      </a>
    {%- else -%}
      <a href="/" class="font-heading text-xl font-bold text-cc-navy">
        {{ shop.name }}
      </a>
    {%- endif -%}

    <nav class="hidden md:flex items-center gap-1 border border-cc-border rounded-pill px-2 py-1 bg-white/60 backdrop-blur-sm shadow-sm">
      {%- for link in section.settings.menu.links -%}
        <a
          href="{{ link.url }}"
          class="px-6 py-3 text-base font-semibold text-cc-navy hover:text-cc-blue transition-colors rounded-pill"
        >
          {{ link.title }}
        </a>
      {%- endfor -%}
    </nav>

    <div class="md:hidden">
      <button type="button" class="text-cc-navy" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
