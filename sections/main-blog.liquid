<section class="py-12 md:py-20">
  <div class="max-w-[1400px] mx-auto px-6">
    <h1 class="font-heading text-3xl md:text-4xl font-bold text-cc-dark mb-10">{{ blog.title }}</h1>

    {%- paginate blog.articles by 9 -%}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {%- for article in blog.articles -%}
          <a href="{{ article.url }}" class="group block">
            {%- if article.image -%}
              <div class="aspect-[16/10] rounded-2xl overflow-hidden bg-cc-light mb-4">
                {{ article.image | image_url: width: 600 | image_tag:
                  class: 'w-full h-full object-cover group-hover:scale-105 transition-transform duration-300',
                  loading: 'lazy',
                  widths: '400,600'
                }}
              </div>
            {%- endif -%}

            <div class="flex items-center gap-2 mb-2">
              <time class="text-xs text-cc-muted" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                {{ article.published_at | date: '%B %d, %Y' }}
              </time>
              {%- if article.tags.size > 0 -%}
                <span class="text-xs text-cc-muted">&middot;</span>
                <span class="text-xs font-medium text-cc-blue">{{ article.tags.first }}</span>
              {%- endif -%}
            </div>

            <h2 class="font-heading text-lg font-semibold text-cc-navy group-hover:text-cc-blue transition-colors">{{ article.title }}</h2>
            {%- if article.excerpt_or_content != blank -%}
              <p class="mt-2 text-sm text-cc-muted line-clamp-2">{{ article.excerpt_or_content | strip_html | truncatewords: 25 }}</p>
            {%- endif -%}
          </a>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="flex justify-center items-center gap-2 mt-12">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="px-4 py-2 text-sm font-semibold text-cc-blue border border-cc-blue rounded-pill hover:bg-cc-blue hover:text-white transition-colors">&larr; Previous</a>
          {%- endif -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="px-4 py-2 text-sm font-semibold text-cc-blue border border-cc-blue rounded-pill hover:bg-cc-blue hover:text-white transition-colors">Next &rarr;</a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Blog",
  "tag": "section",
  "settings": []
}
{% endschema %}
