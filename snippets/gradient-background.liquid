{% comment %}
  Reusable animated WebGL gradient background with optional bottom wave.

  Usage:
    {% render 'gradient-background',
      color_1: '#1D4AFE',
      color_2: '#6C3AED',
      color_3: '#0D1340',
      color_4: '#3B82F6',
      color_5: '#112F54',
      speed: 3,
      intensity: 4,
      show_wave: true,
      wave_color: '#ffffff',
      wave_height: 80
    %}
{% endcomment %}

{%- liquid
  assign c1 = color_1 | default: '#1D4AFE'
  assign c2 = color_2 | default: '#6C3AED'
  assign c3 = color_3 | default: '#0D1340'
  assign c4 = color_4 | default: '#3B82F6'
  assign c5 = color_5 | default: '#112F54'
  assign spd_raw = speed | default: 3
  assign amt_raw = intensity | default: 4
  assign wave_on = show_wave | default: true
  assign w_color = wave_color | default: '#ffffff'
  assign w_height = wave_height | default: 20
  assign lines_on = show_lines | default: true
  assign l_color = line_color | default: '#ffffff'
  assign l_opacity = line_opacity | default: 15
  assign l_count = line_count | default: 30
  assign l_thickness = line_thickness | default: 3
-%}

<canvas
  class="gradient-canvas absolute inset-0 w-full h-full"
  data-colors='{{ c1 }},{{ c2 }},{{ c3 }},{{ c4 }},{{ c5 }}'
  data-speed="{{ spd_raw }}"
  data-intensity="{{ amt_raw }}"
  data-show-lines="{{ lines_on }}"
  data-line-color="{{ l_color }}"
  data-line-opacity="{{ l_opacity }}"
  data-line-count="{{ l_count }}"
  data-line-thickness="{{ l_thickness }}"
  aria-hidden="true"
></canvas>

{%- if wave_on -%}
  <div
    class="gradient-wave-wrap absolute bottom-0 left-0 right-0 pointer-events-none"
    data-wave-color="{{ w_color }}"
    data-wave-height="{{ w_height }}"
    style="z-index: 3; height: {{ w_height }}%;"
  ></div>
{%- endif -%}

<script type="module">
(function() {
  /* ── Hex → {r, g, b} (0-255) ── */
  function hexToRgb(hex) {
    hex = hex.replace('#', '');
    return {
      r: parseInt(hex.slice(0, 2), 16),
      g: parseInt(hex.slice(2, 4), 16),
      b: parseInt(hex.slice(4, 6), 16)
    };
  }

  /* ── Render wave transition via JS ── */
  document.querySelectorAll('.gradient-wave-wrap').forEach(wrap => {
    const hex = wrap.dataset.waveColor || '#ffffff';
    const { r, g, b } = hexToRgb(hex);

    const svgNS = 'http://www.w3.org/2000/svg';
    const svg = document.createElementNS(svgNS, 'svg');
    svg.setAttribute('viewBox', '0 0 1440 100');
    svg.setAttribute('preserveAspectRatio', 'none');
    svg.style.cssText = 'position:absolute;bottom:0;left:0;width:100%;height:100%;';

    /* Create <defs> with vertical linear gradients — transparent top, solid bottom */
    const defs = document.createElementNS(svgNS, 'defs');

    const waves = [
      { id: 'wg1', dur: '8s', vals: 'M0,60 C240,80 480,40 720,60 C960,80 1200,40 1440,60 L1440,100 L0,100 Z;M0,50 C240,30 480,70 720,50 C960,30 1200,70 1440,50 L1440,100 L0,100 Z;M0,60 C240,80 480,40 720,60 C960,80 1200,40 1440,60 L1440,100 L0,100 Z', topAlpha: 0, bottomAlpha: 0.5 },
      { id: 'wg2', dur: '6s', vals: 'M0,70 C360,55 600,85 900,65 C1100,50 1300,80 1440,70 L1440,100 L0,100 Z;M0,75 C360,90 600,55 900,75 C1100,90 1300,60 1440,75 L1440,100 L0,100 Z;M0,70 C360,55 600,85 900,65 C1100,50 1300,80 1440,70 L1440,100 L0,100 Z', topAlpha: 0, bottomAlpha: 0.8 },
      { id: 'wg3', dur: '10s', vals: 'M0,85 C200,78 400,92 720,82 C1040,72 1240,90 1440,85 L1440,100 L0,100 Z;M0,82 C200,90 400,75 720,85 C1040,95 1240,78 1440,82 L1440,100 L0,100 Z;M0,85 C200,78 400,92 720,82 C1040,72 1240,90 1440,85 L1440,100 L0,100 Z', topAlpha: 0, bottomAlpha: 1 },
    ];

    waves.forEach(w => {
      const grad = document.createElementNS(svgNS, 'linearGradient');
      grad.setAttribute('id', w.id);
      grad.setAttribute('x1', '0'); grad.setAttribute('y1', '0');
      grad.setAttribute('x2', '0'); grad.setAttribute('y2', '1');

      const stop1 = document.createElementNS(svgNS, 'stop');
      stop1.setAttribute('offset', '0%');
      stop1.setAttribute('stop-color', `rgba(${r},${g},${b},${w.topAlpha})`);

      const stop2 = document.createElementNS(svgNS, 'stop');
      stop2.setAttribute('offset', '100%');
      stop2.setAttribute('stop-color', `rgba(${r},${g},${b},${w.bottomAlpha})`);

      grad.appendChild(stop1);
      grad.appendChild(stop2);
      defs.appendChild(grad);
    });

    svg.appendChild(defs);

    waves.forEach(w => {
      const path = document.createElementNS(svgNS, 'path');
      path.setAttribute('fill', `url(#${w.id})`);
      const anim = document.createElementNS(svgNS, 'animate');
      anim.setAttribute('attributeName', 'd');
      anim.setAttribute('dur', w.dur);
      anim.setAttribute('repeatCount', 'indefinite');
      anim.setAttribute('values', w.vals);
      path.appendChild(anim);
      svg.appendChild(path);
    });

    wrap.appendChild(svg);
  });

  const THREE_CDN = 'https://unpkg.com/three@0.160.0/build/three.module.js';

  const vertexShader = `
uniform vec2 uFrequency;
uniform float uTime;
uniform float uAmount;
uniform float uSpeed;
uniform vec3 uColor[5];
varying vec2 vUv;
varying vec3 vColor;
varying float vDisplacement;

vec4 permute(vec4 x){return mod(((x*34.0)+1.0)*x, 289.0);}
vec4 taylorInvSqrt(vec4 r){return 1.79284291400159 - 0.85373472095314 * r;}

float snoise(vec3 v){
  const vec2 C = vec2(1.0/6.0, 1.0/3.0);
  const vec4 D = vec4(0.0, 0.5, 1.0, 2.0);
  vec3 i = floor(v + dot(v, C.yyy));
  vec3 x0 = v - i + dot(i, C.xxx);
  vec3 g = step(x0.yzx, x0.xyz);
  vec3 l = 1.0 - g;
  vec3 i1 = min(g.xyz, l.zxy);
  vec3 i2 = max(g.xyz, l.zxy);
  vec3 x1 = x0 - i1 + C.xxx;
  vec3 x2 = x0 - i2 + 2.0 * C.xxx;
  vec3 x3 = x0 - 1.0 + 3.0 * C.xxx;
  i = mod(i, 289.0);
  vec4 p = permute(permute(permute(
    i.z + vec4(0.0, i1.z, i2.z, 1.0))
    + i.y + vec4(0.0, i1.y, i2.y, 1.0))
    + i.x + vec4(0.0, i1.x, i2.x, 1.0));
  float n_ = 1.0/7.0;
  vec3 ns = n_ * D.wyz - D.xzx;
  vec4 j = p - 49.0 * floor(p * ns.z * ns.z);
  vec4 x_ = floor(j * ns.z);
  vec4 y_ = floor(j - 7.0 * x_);
  vec4 x = x_ * ns.x + ns.yyyy;
  vec4 y = y_ * ns.x + ns.yyyy;
  vec4 h = 1.0 - abs(x) - abs(y);
  vec4 b0 = vec4(x.xy, y.xy);
  vec4 b1 = vec4(x.zw, y.zw);
  vec4 s0 = floor(b0)*2.0 + 1.0;
  vec4 s1 = floor(b1)*2.0 + 1.0;
  vec4 sh = -step(h, vec4(0.0));
  vec4 a0 = b0.xzyw + s0.xzyw*sh.xxyy;
  vec4 a1 = b1.xzyw + s1.xzyw*sh.zzww;
  vec3 p0 = vec3(a0.xy,h.x);
  vec3 p1 = vec3(a0.zw,h.y);
  vec3 p2 = vec3(a1.xy,h.z);
  vec3 p3 = vec3(a1.zw,h.w);
  vec4 norm = taylorInvSqrt(vec4(dot(p0,p0),dot(p1,p1),dot(p2,p2),dot(p3,p3)));
  p0 *= norm.x; p1 *= norm.y; p2 *= norm.z; p3 *= norm.w;
  vec4 m = max(0.6 - vec4(dot(x0,x0),dot(x1,x1),dot(x2,x2),dot(x3,x3)), 0.0);
  m = m * m;
  return 42.0 * dot(m*m, vec4(dot(p0,x0),dot(p1,x1),dot(p2,x2),dot(p3,x3)));
}

void main(){
  vec4 modelPosition = modelMatrix * vec4(position, 1.0);
  vec2 noiseCoord = uv * vec2(uFrequency.x, uFrequency.y);
  float noise = snoise(vec3(noiseCoord.x + uTime*0.02, noiseCoord.y, uTime * uSpeed));
  float displacement = noise * uAmount;
  modelPosition.y += displacement;
  vDisplacement = displacement;

  vColor = uColor[4];
  for(int i = 0; i < 4; i++){
    float noiseFlow = 0.0002 + float(i)*0.05;
    float noiseSpeed = 0.0001 + float(i)*0.03;
    float noiseSeed = 1.0 + float(i)*10.0;
    vec2 noiseFreq = vec2(0.3, 0.6);
    float noiseFloor = 0.1;
    float noiseCeiling = 0.6 + float(i)*0.08;
    float n = smoothstep(noiseFloor, noiseCeiling,
      snoise(vec3(
        noiseCoord.x*noiseFreq.x + uTime*noiseFlow,
        noiseCoord.y*noiseFreq.y,
        uTime * noiseSpeed + noiseSeed
      ))
    );
    vColor = mix(vColor, uColor[i], n);
  }

  gl_Position = projectionMatrix * viewMatrix * modelPosition;
  vUv = uv;
}`;

  const fragmentShader = `
precision mediump float;
varying vec2 vUv;
varying vec3 vColor;
varying float vDisplacement;

uniform bool uShowLines;
uniform vec3 uLineColor;
uniform float uLineOpacity;
uniform float uLineCount;
uniform float uLineThickness;

void main(){
  vec3 color = vColor;

  if (uShowLines) {
    /* Use UV.y + displacement to make lines follow the wave surface */
    float waveY = vUv.y + vDisplacement * 2.0;

    /* Create repeating lines along the wave — sin gives smooth curves */
    float linePattern = sin(waveY * uLineCount * 3.14159);

    /* Sharpen into thin lines using smoothstep — thickness controls width */
    float thickness = 1.0 - uLineThickness * 0.01;
    float line = smoothstep(thickness, thickness + 0.02, linePattern);

    /* Blend the line color over the gradient */
    color = mix(color, uLineColor, line * uLineOpacity);
  }

  gl_FragColor = vec4(color, 1.0);
}`;

  function hexToRGB(hex) {
    hex = hex.replace('#', '');
    return [
      parseInt(hex.slice(0, 2), 16) / 255,
      parseInt(hex.slice(2, 4), 16) / 255,
      parseInt(hex.slice(4, 6), 16) / 255
    ];
  }

  async function initGradient(canvas) {
    const THREE = await import(THREE_CDN);

    const colors = canvas.dataset.colors.split(',').map(c => {
      const [r, g, b] = hexToRGB(c.trim());
      return new THREE.Vector3(r, g, b);
    });
    const speedRaw = parseFloat(canvas.dataset.speed) || 3;
    const intensityRaw = parseFloat(canvas.dataset.intensity) || 4;
    const speed = 0.005 + (speedRaw / 10) * 0.075;
    const intensity = 0.05 + (intensityRaw / 10) * 0.45;

    /* Line settings */
    const showLines = canvas.dataset.showLines === 'true';
    const lineColorHex = canvas.dataset.lineColor || '#ffffff';
    const [lr, lg, lb] = hexToRGB(lineColorHex);
    const lineOpacity = (parseFloat(canvas.dataset.lineOpacity) || 15) / 100;
    const lineCount = parseFloat(canvas.dataset.lineCount) || 30;
    const lineThickness = parseFloat(canvas.dataset.lineThickness) || 3;

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(35, canvas.clientWidth / canvas.clientHeight, 0.1, 100);
    camera.position.set(0, 0.5, 0.4);
    camera.lookAt(0, 0, 0);

    const geometry = new THREE.PlaneGeometry(1.5, 1.5, 200, 200);
    const material = new THREE.ShaderMaterial({
      uniforms: {
        uFrequency: { value: new THREE.Vector2(3, 6) },
        uTime: { value: 0 },
        uAmount: { value: intensity },
        uSpeed: { value: speed },
        uColor: { value: colors },
        uShowLines: { value: showLines },
        uLineColor: { value: new THREE.Vector3(lr, lg, lb) },
        uLineOpacity: { value: lineOpacity },
        uLineCount: { value: lineCount },
        uLineThickness: { value: lineThickness },
      },
      vertexShader,
      fragmentShader,
    });

    const mesh = new THREE.Mesh(geometry, material);
    mesh.rotation.x = -Math.PI / 2;
    scene.add(mesh);

    function onResize() {
      const w = canvas.clientWidth;
      const h = canvas.clientHeight;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }

    const ro = new ResizeObserver(onResize);
    ro.observe(canvas.parentElement);
    onResize();

    const clock = new THREE.Clock();
    let raf;
    function animate() {
      raf = requestAnimationFrame(animate);
      material.uniforms.uTime.value = clock.getElapsedTime();
      renderer.render(scene, camera);
    }

    const io = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) { clock.start(); animate(); }
      else { cancelAnimationFrame(raf); clock.stop(); }
    }, { threshold: 0 });
    io.observe(canvas);
  }

  document.querySelectorAll('canvas.gradient-canvas').forEach(initGradient);
})();
</script>
