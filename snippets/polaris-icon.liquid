{% comment %}
  Renders a Polaris icon by name.

  Usage: {% render 'polaris-icon', icon: 'cart', size: 20, color: '#1D4AFE' %}

  Supports all 534 Polaris icons. Common ones are inlined for performance,
  the rest load from CDN automatically.

  Full list: https://polaris.shopify.com/icons
  Use lowercase-hyphenated names: cart, star-filled, order-draft, etc.
{% endcomment %}

{%- assign icon_size = size | default: 20 -%}
{%- assign icon_color = color | default: 'currentColor' -%}

{%- liquid
  assign is_inline = false
  case icon
    when 'marketing', 'registration', 'finances', 'engagement', 'payroll', 'cart', 'store', 'analytics', 'apps', 'settings', 'star', 'rocket', 'bolt', 'shield', 'chat', 'users', 'globe', 'check-circle', 'target', 'clock', 'heart', 'home', 'search', 'plus', 'minus', 'edit', 'delete', 'email', 'phone', 'image', 'lock', 'money', 'discount', 'gift-card', 'order', 'product', 'person', 'notification', 'flag', 'link', 'eye-dropper', 'magic'
      assign is_inline = true
  endcase
-%}

{%- if is_inline -%}
  {%- case icon -%}

    {%- when 'marketing' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M3.5 11V5.5a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2V11a2 2 0 0 1-2 2h-9a2 2 0 0 1-2-2Z" stroke="{{ icon_color }}" stroke-width="1.5"/><path d="M7 16.5h6" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round"/><path d="M10 13v3.5" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round"/></svg>

    {%- when 'registration' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M4 4.5h12a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1v-9a1 1 0 0 1 1-1Z" stroke="{{ icon_color }}" stroke-width="1.5"/><path d="M6 8h4M6 11h8" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round"/></svg>

    {%- when 'finances' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M10 3v14M13 5.5H8.5a2.5 2.5 0 0 0 0 5h3a2.5 2.5 0 0 1 0 5H7" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>

    {%- when 'engagement' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M10 17s-6-4.35-6-8.5A4 4 0 0 1 10 5.18 4 4 0 0 1 16 8.5c0 4.15-6 8.5-6 8.5Z" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>

    {%- when 'payroll' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><rect x="3" y="4" width="14" height="12" rx="2" stroke="{{ icon_color }}" stroke-width="1.5"/><path d="M3 8h14" stroke="{{ icon_color }}" stroke-width="1.5"/><path d="M7 12h2M13 12h1" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round"/></svg>

    {%- when 'cart' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M3 3h1.5l1.2 6.4a2 2 0 0 0 2 1.6h6.1a2 2 0 0 0 2-1.6L17 5H5.4" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="8.5" cy="15.5" r="1" stroke="{{ icon_color }}" stroke-width="1.5"/><circle cx="14.5" cy="15.5" r="1" stroke="{{ icon_color }}" stroke-width="1.5"/></svg>

    {%- when 'store' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M3 7l1-4h12l1 4M3 7h14M3 7v9a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V7" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linejoin="round"/><path d="M8 17v-5h4v5" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linejoin="round"/></svg>

    {%- when 'analytics' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M3 17h14M5 13v4M9 9v8M13 11v6M17 7v10" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round"/></svg>

    {%- when 'apps' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><rect x="3" y="3" width="6" height="6" rx="1" stroke="{{ icon_color }}" stroke-width="1.5"/><rect x="11" y="3" width="6" height="6" rx="1" stroke="{{ icon_color }}" stroke-width="1.5"/><rect x="3" y="11" width="6" height="6" rx="1" stroke="{{ icon_color }}" stroke-width="1.5"/><rect x="11" y="11" width="6" height="6" rx="1" stroke="{{ icon_color }}" stroke-width="1.5"/></svg>

    {%- when 'settings' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="2.5" stroke="{{ icon_color }}" stroke-width="1.5"/><path d="M10 2v2M10 16v2M17 10h-2M5 10H3M15.07 4.93l-1.41 1.41M6.34 13.66l-1.41 1.41M15.07 15.07l-1.41-1.41M6.34 6.34L4.93 4.93" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round"/></svg>

    {%- when 'star' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M10 2l2.47 5.01L18 7.75l-4 3.9.94 5.5L10 14.52 5.06 17.15l.94-5.5-4-3.9 5.53-.74L10 2Z" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linejoin="round"/></svg>

    {%- when 'rocket' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M10 14s-1.5 1-3 3c0 0-1-4 1-6M10 14s1.5 1 3 3c0 0 1-4-1-6M10 14V7m0 0C10 4 12 2 12 2s4 2 4 7c0 2-1.5 3.5-3 5M10 7C10 4 8 2 8 2S4 4 4 9c0 2 1.5 3.5 3 5" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="10" cy="10" r="1" fill="{{ icon_color }}"/></svg>

    {%- when 'bolt' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M11 2L5 11h5l-1 7 6-9h-5l1-7Z" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>

    {%- when 'shield' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M10 2L3 5.5v4c0 4.5 3 8 7 9.5 4-1.5 7-5 7-9.5v-4L10 2Z" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linejoin="round"/></svg>

    {%- when 'chat' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M4 4h12a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1h-4l-3 3v-3H4a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1Z" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linejoin="round"/></svg>

    {%- when 'users' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><circle cx="7" cy="7" r="2.5" stroke="{{ icon_color }}" stroke-width="1.5"/><path d="M2 16c0-2.5 2-4.5 5-4.5s5 2 5 4.5" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round"/><circle cx="14" cy="7" r="2" stroke="{{ icon_color }}" stroke-width="1.5"/><path d="M14 11.5c2.5 0 4 1.5 4 3.5" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round"/></svg>

    {%- when 'globe' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="{{ icon_color }}" stroke-width="1.5"/><path d="M3 8h14M3 12h14" stroke="{{ icon_color }}" stroke-width="1.5"/><ellipse cx="10" cy="10" rx="3" ry="7.5" stroke="{{ icon_color }}" stroke-width="1.5"/></svg>

    {%- when 'check-circle' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="{{ icon_color }}" stroke-width="1.5"/><path d="M7 10l2 2 4-4" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>

    {%- when 'target' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="{{ icon_color }}" stroke-width="1.5"/><circle cx="10" cy="10" r="4" stroke="{{ icon_color }}" stroke-width="1.5"/><circle cx="10" cy="10" r="1" fill="{{ icon_color }}"/></svg>

    {%- when 'clock' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="{{ icon_color }}" stroke-width="1.5"/><path d="M10 6v4l3 2" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>

    {%- when 'heart' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M10 17s-6-4.35-6-8.5A4 4 0 0 1 10 5.18 4 4 0 0 1 16 8.5c0 4.15-6 8.5-6 8.5Z" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>

    {%- when 'home' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M3 10l7-7 7 7" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M5 8v7a1 1 0 0 0 1 1h3v-4h2v4h3a1 1 0 0 0 1-1V8" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>

    {%- when 'search' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><circle cx="9" cy="9" r="5.5" stroke="{{ icon_color }}" stroke-width="1.5"/><path d="M13.5 13.5L17 17" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round"/></svg>

    {%- when 'plus' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M10 4v12M4 10h12" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round"/></svg>

    {%- when 'minus' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M4 10h12" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round"/></svg>

    {%- when 'edit' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M12.5 3.5l4 4L7 17H3v-4l9.5-9.5Z" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linejoin="round"/></svg>

    {%- when 'delete' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M5 5h10l-1 12H6L5 5ZM3 5h14M8 5V3h4v2" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>

    {%- when 'email' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><rect x="3" y="4" width="14" height="12" rx="2" stroke="{{ icon_color }}" stroke-width="1.5"/><path d="M3 6l7 5 7-5" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>

    {%- when 'phone' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M5 3h3l2 4-2.5 1.5A8.5 8.5 0 0 0 11.5 12.5L13 10l4 2v3a2 2 0 0 1-2 2A13 13 0 0 1 3 5a2 2 0 0 1 2-2Z" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linejoin="round"/></svg>

    {%- when 'image' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><rect x="3" y="3" width="14" height="14" rx="2" stroke="{{ icon_color }}" stroke-width="1.5"/><circle cx="7.5" cy="7.5" r="1.5" stroke="{{ icon_color }}" stroke-width="1.5"/><path d="M3 14l4-4 3 3 2-2 5 5" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>

    {%- when 'lock' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><rect x="4" y="9" width="12" height="8" rx="2" stroke="{{ icon_color }}" stroke-width="1.5"/><path d="M7 9V6a3 3 0 0 1 6 0v3" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round"/></svg>

    {%- when 'money' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><rect x="2" y="4" width="16" height="12" rx="2" stroke="{{ icon_color }}" stroke-width="1.5"/><circle cx="10" cy="10" r="2.5" stroke="{{ icon_color }}" stroke-width="1.5"/><path d="M5 7v0M15 13v0" stroke="{{ icon_color }}" stroke-width="2" stroke-linecap="round"/></svg>

    {%- when 'discount' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M14 6L6 14" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round"/><circle cx="7" cy="7" r="1.5" stroke="{{ icon_color }}" stroke-width="1.5"/><circle cx="13" cy="13" r="1.5" stroke="{{ icon_color }}" stroke-width="1.5"/></svg>

    {%- when 'gift-card' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><rect x="2" y="6" width="16" height="11" rx="2" stroke="{{ icon_color }}" stroke-width="1.5"/><path d="M2 10h16M10 6v11" stroke="{{ icon_color }}" stroke-width="1.5"/><path d="M10 6s-2-3-4-3 1 3 4 3m0 0s2-3 4-3-1 3-4 3" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round"/></svg>

    {%- when 'order' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><rect x="4" y="2" width="12" height="16" rx="1" stroke="{{ icon_color }}" stroke-width="1.5"/><path d="M7 6h6M7 9h6M7 12h3" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round"/></svg>

    {%- when 'product' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M10 2l7 4v8l-7 4-7-4V6l7-4Z" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linejoin="round"/><path d="M10 10l7-4M10 10v8M10 10L3 6" stroke="{{ icon_color }}" stroke-width="1.5"/></svg>

    {%- when 'person' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="6" r="3" stroke="{{ icon_color }}" stroke-width="1.5"/><path d="M4 17c0-3 2.5-5 6-5s6 2 6 5" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round"/></svg>

    {%- when 'notification' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M5 8a5 5 0 0 1 10 0v3l2 2H3l2-2V8Z" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linejoin="round"/><path d="M8 15a2 2 0 0 0 4 0" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round"/></svg>

    {%- when 'flag' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M4 3v14M4 3h10l-2 4 2 4H4" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>

    {%- when 'link' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M8 12l4-4M6.5 10.5l-1 1a3.5 3.5 0 0 0 5 5l1-1M13.5 9.5l1-1a3.5 3.5 0 0 0-5-5l-1 1" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round"/></svg>

    {%- when 'eye-dropper' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M12 4l4 4-8 8H4v-4l8-8Zm0 0l1.5-1.5a2 2 0 0 1 3 0l1 1a2 2 0 0 1 0 3L16 8" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linejoin="round"/></svg>

    {%- when 'magic' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><path d="M3 17l10-10M13 7l-2-2M14 3l1 2 2 1-2 1-1 2-1-2-2-1 2-1 1-2Z" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>

  {%- endcase -%}

{%- else -%}
  {%- comment -%} Load from Polaris Icons CDN {%- endcomment -%}
  {%- liquid
    assign parts = icon | split: '-'
    assign pascal_name = ''
    for part in parts
      assign first_char = part | slice: 0 | upcase
      assign rest = part | slice: 1, 100
      assign pascal_name = pascal_name | append: first_char | append: rest
    endfor
    assign pascal_name = pascal_name | append: 'Icon'
    assign cdn_url = 'https://unpkg.com/@shopify/polaris-icons@latest/dist/svg/' | append: pascal_name | append: '.svg'
  -%}
  <span class="polaris-icon-cdn inline-flex" style="width:{{ icon_size }}px; height:{{ icon_size }}px; color:{{ icon_color }};" data-icon-url="{{ cdn_url }}">
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="{{ icon_color }}" stroke-width="1.5"/></svg>
  </span>
{%- endif -%}
